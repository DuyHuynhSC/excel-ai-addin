<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp 
  xmlns="http://schemas.microsoft.com/office/appshere/manifest/1.1" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" 
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" 
  xsi:type="TaskPaneApp">
  
  <Id>d53fa652-32a8-4c28-98e3-85f02be8d120</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Internal Dev Team</ProviderName>
  <DefaultLocale>vi-VN</DefaultLocale>
  <DisplayName DefaultValue="Trợ Lý Excel AI (Ollama)" />
  <Description DefaultValue="Tích hợp dịch thuật, tóm tắt và phân tích dữ liệu trực tiếp bằng mô hình ngôn ngữ lớn (LLM)." />
  
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-80.png" />
  
  <SupportUrl DefaultValue="https://localhost:3000/support" />
  
  <Hosts>
    <Host Name="Workbook" />
  </Hosts>
  
  <DefaultSettings>
    <SourceLocation DefaultValue="http://localhost:3000/taskpane.html" />
  </DefaultSettings>
  
  <Permissions>ReadWriteDocument</Permissions>
  
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        
        <!-- Khai báo Shared Runtime giúp chia sẻ dữ liệu và trạng thái giữa Custom Functions và Task Pane -->
        <Runtimes>
          <Runtime resid="Taskpane.Url" lifetime="long" />
        </Runtimes>
        
        <AllFormulas />
        
        <DesktopFormFactor>
          <!-- Cấu hình Ribbon Commands -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="GroupAI">
                <Label resid="GroupAI.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16" />
                  <bt:Image size="32" resid="Icon.32" />
                  <bt:Image size="80" resid="Icon.80" />
                </Icon>
                
                <Control xsi:type="Button" id="ShowTaskpaneButton">
                  <Label resid="ShowTaskpane.Label" />
                  <SuperTip>
                    <Title resid="ShowTaskpane.Label" />
                    <Description resid="ShowTaskpane.Tooltip" />
                  </SuperTip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16" />
                    <bt:Image size="32" resid="Icon.32" />
                    <bt:Image size="80" resid="Icon.80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>SharedRuntimeTaskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
          
          <!-- Khai báo Custom Functions (Hàm Tự Chọn) -->
          <ExtensionPoint xsi:type="CustomFunctions">
            <Script>
              <SourceLocation resid="Taskpane.Url" />
            </Script>
            <Page>
              <SourceLocation resid="Taskpane.Url" />
            </Page>
            <Namespace resid="Functions.Namespace" />
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://localhost:3000/assets/icon-16.png" />
        <bt:Image id="Icon.32" DefaultValue="https://localhost:3000/assets/icon-32.png" />
        <bt:Image id="Icon.80" DefaultValue="https://localhost:3000/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="http://localhost:3000/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupAI.Label" DefaultValue="Trợ Lý AI" />
        <bt:String id="ShowTaskpane.Label" DefaultValue="Mở Bảng Điều Khiển" />
        <bt:String id="Functions.Namespace" DefaultValue="AI" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ShowTaskpane.Tooltip" DefaultValue="Mở thanh Sidebar để sử dụng các tính năng dịch thuật, phân tích dữ liệu và cấu hình AI." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
