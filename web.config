<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Cấu hình CORS để cho phép gọi API tự do từ Add-in -->
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="*" />
        <add name="Access-Control-Allow-Headers" value="Origin, X-Requested-With, Content-Type, Accept, Authorization, X-Target-Url" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, OPTIONS, PUT, DELETE" />
        <add name="Access-Control-Allow-Credentials" value="true" />
      </customHeaders>
    </httpProtocol>

    <!-- Cấu hình Rewrite URL làm Reverse Proxy chuyển tiếp yêu cầu đến Gateway nội bộ -->
    <!-- Lưu ý: Cần cài đặt URL Rewrite và Application Request Routing (ARR) trên IIS, đồng thời tích chọn "Enable proxy" trong cài đặt ARR -->
    <rewrite>
      <rules>
        <rule name="Vite Clean URL Routing" stopProcessing="true">
          <match url="^taskpane$" />
          <action type="Rewrite" url="taskpane.html" />
        </rule>
        <rule name="IIS Reverse Proxy to Corporate Gateway" stopProcessing="true">
          <match url="^api-proxy/(.*)" />
          <action type="Rewrite" url="https://models-gateway.fujinet.net/v1/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Định nghĩa kiểu tệp tin tĩnh mở rộng cho manifest.json và functions.json -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>
  </system.webServer>
</configuration>
